{
  "manifest_version": 3,
  "name": "GraphQL & JSON Network Extractor",
  "version": "1.0.0",
  "description": "Captures all GraphQL and JSON responses from any website's network traffic in real time and lets you download them as a JSON file.",
  "permissions": ["storage", "downloads", "tabs", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GraphQL & JSON Extractor"
  }
}
